# ===== Copy this file to .env and fill in real values. Never commit .env. =====

# --- Grok / xAI API (Responder + Get Help Now agent) ---
# Get a key at https://console.x.ai  (Gemini keys start with "AIza...";
# if yours started with "AQ" it was likely copy-pasted from the wrong place —
# Grok keys look like "xai-...")
GROK_API_KEY=xai-your_key_here
# Check https://docs.x.ai/docs/models for the current model name
GROK_MODEL=grok-4-fast

# --- OpenWeatherMap (Sentinel risk agent) ---
# Free tier key at https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweathermap_key_here

# --- Google Maps Platform (Wayfinder — hospitals + routing) ---
# Enable "Places API (New)" and "Directions API" at https://console.cloud.google.com
GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# --- Firebase (Firestore database + Cloud Messaging push notifications) ---
# 1. Create a project at https://console.firebase.google.com
# 2. Enable "Firestore Database" (test mode is fine for a hackathon)
# 3. Enable "Cloud Messaging"
# 4. Project settings > Service accounts > Generate new private key
#    -> save the downloaded JSON file as firebase-service-account.json
#    in this backend folder (it's already in .gitignore, keep it private)
FIREBASE_CREDENTIALS_PATH=firebase-service-account.json
# The topic devices subscribe to so they receive SOS/alert pushes
FIREBASE_ALERT_TOPIC=resq_alerts

# --- App ---
DEFAULT_CITY=Hyderabad
DEFAULT_LAT=17.3850
DEFAULT_LON=78.4867
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:5501,http://127.0.0.1:5501,null
